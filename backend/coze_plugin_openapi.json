                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "CozePluginToken": []
          }
        ]
      }
    },
    "/api/coze/confirm_and_publish": {
      "post": {
        "summary": "Confirm And Publish",
