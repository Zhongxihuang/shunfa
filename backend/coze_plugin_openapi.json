{
  "openapi": "3.1.0",
  "info": {
    "title": "顺发 Coze Plugin API",
    "description": "顺发AI洞察者后端，供Coze工作流调用",
    "version": "1.0.0"
  },
  "paths": {
    "/api/coze/get_hot_topics": {
      "get": {
        "summary": "Get Hot Topics",
        "description": "Return today's top-scored pending hot topics for the daily push.",
        "operationId": "get_hot_topics_api_coze_get_hot_topics_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 3,
              "title": "Limit"
            }
          },
          {
            "name": "X-Coze-Plugin-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Coze-Plugin-Token"
            }
          },
          {
            "name": "X-Feishu-User-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "首选的飞书用户ID；若未注入，后端会尝试兼容其他用户标识头并降级到匿名Coze用户"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetHotTopicsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "CozePluginToken": []
          }
        ]
      }
    },
    "/api/coze/quick_generate": {
      "post": {
        "summary": "Coze Quick Generate",
        "description": "Quick mode: generate content from hot topic + angle in ~30s. Stateless.",
        "operationId": "coze_quick_generate_api_coze_quick_generate_post",
        "parameters": [
          {
            "name": "X-Coze-Plugin-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Coze-Plugin-Token"
            }
          },
          {
            "name": "X-Feishu-User-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "首选的飞书用户ID；若未注入，后端会尝试兼容其他用户标识头并降级到匿名Coze用户"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuickGeneratePluginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuickGeneratePluginResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "CozePluginToken": []
          }
        ]
      }
    },
    "/api/coze/start_deep_mode": {
      "post": {
        "summary": "Start Deep Mode",
        "description": "Create a deep mode CheckIn session. Returns checkin_id for subsequent messages.",
