# ── 必填 ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-strong-random-secret-at-least-32-chars
API_KEY_ENCRYPTION_SECRET=your-strong-random-encryption-secret

# ── AI 配置（BYOK 模式时可不填，用户使用自己的 Key）──────────────────────────
# BYOK 推荐：留空，让用户在 Settings 页面填写自己的 DeepSeek API Key
# 如果填写，则作为未配置个人 Key 的用户的 fallback（仅本地开发建议使用）
DEEPSEEK_API_KEY=
# 设为 true 后，强制所有用户使用自己的 Key，环境变量 Key 将不生效
REQUIRE_USER_API_KEY=false

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./shunfa.db

# ── 跨域（Web 端部署后，填入 Vercel 域名）────────────────────────────────────
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── 运行环境 ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── 可选：旧版单密码登录 fallback（新版用注册/登录，此项可不填）──────────────
# ADMIN_PASSWORD=choose_a_strong_web_password

# ── 可选：高级集成（飞书、Coze 等）──────────────────────────────────────────
# COZE_PLUGIN_TOKEN=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BITABLE_APP_TOKEN=
# BITABLE_HOT_TOPIC_TABLE_ID=
# BITABLE_VOICE_RECORD_TABLE_ID=

JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=720
