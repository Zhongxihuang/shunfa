.streak-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98) 0%, rgba(246, 241, 233, 0.98) 100%);
  border: 2rpx solid rgba(182, 172, 153, 0.52);
  box-shadow: 0 8rpx 24rpx rgba(43, 35, 24, 0.06);
  flex: 1;
}

.badge-normal {
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(248, 244, 235, 0.98));
}
.badge-normal .streak-number { color: var(--color-ink); }

.badge-rare {
  background: linear-gradient(180deg, rgba(232, 238, 228, 0.96), rgba(250, 248, 242, 0.98));
  border-color: rgba(29, 143, 87, 0.18);
}
.badge-rare .streak-number { color: var(--color-primary-dark); }

.badge-epic {
  background: linear-gradient(180deg, rgba(245, 240, 231, 0.98), rgba(238, 232, 221, 0.98));
  border-color: rgba(182, 172, 153, 0.7);
}
.badge-epic .streak-number { color: var(--color-ink); }

.badge-legendary {
  background: linear-gradient(180deg, rgba(230, 237, 227, 0.98), rgba(242, 239, 232, 0.98));
  border-color: rgba(29, 143, 87, 0.24);
  box-shadow: 0 10rpx 28rpx rgba(29, 143, 87, 0.08);
}
.badge-legendary .streak-number { color: var(--color-primary-dark); }

.streak-number {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1;
  font-family: var(--font-family-display);
}
.streak-label {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  font-weight: 500;
}
.fire {
  font-size: 32rpx;
  line-height: 1;
  opacity: 0.88;
}
