.streak-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-pill);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-card);
  flex: 1;
}

/* Tier: Normal (1-2 days) */
.badge-normal .streak-number { color: #fab005; }

/* Tier: Rare (3-6 days) */
.badge-rare {
  background: linear-gradient(135deg, #e8fff0, #d0f5de);
  border: 1.5rpx solid rgba(7, 193, 96, 0.25);
}
.badge-rare .streak-number { color: var(--color-primary); }

/* Tier: Epic (7-29 days) */
.badge-epic {
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
  border: 1.5rpx solid rgba(30, 100, 250, 0.25);
  animation: subtleGlow 3s ease-in-out infinite;
}
.badge-epic .streak-number { color: #1565c0; }

/* Tier: Legendary (30+ days) */
.badge-legendary {
  background: linear-gradient(135deg, #fff8e1, #ffe082, #ffd54f);
  border: 1.5rpx solid rgba(255, 160, 0, 0.4);
  box-shadow: 0 4rpx 24rpx rgba(255, 160, 0, 0.3);
  animation: legendaryGlow 2s ease-in-out infinite;
}
.badge-legendary .streak-number { color: #e65100; font-weight: 800; }

@keyframes subtleGlow {
  0%, 100% { box-shadow: var(--shadow-card); }
  50% { box-shadow: 0 4rpx 20rpx rgba(30, 100, 250, 0.2); }
}

@keyframes legendaryGlow {
  0%, 100% { box-shadow: 0 4rpx 24rpx rgba(255, 160, 0, 0.3); }
  50% { box-shadow: 0 4rpx 36rpx rgba(255, 160, 0, 0.5); }
}

.streak-number {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
}
.streak-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}
.fire {
  font-size: 36rpx;
  line-height: 1;
}
