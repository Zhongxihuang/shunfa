.card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 28rpx 28rpx 0;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.card--hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.card--selected {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, #f0fff6 0%, var(--color-bg-card) 70%);
  box-shadow: 0 4rpx 24rpx var(--color-shadow-primary);
}

.card__index {
  flex-shrink: 0;
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card__index-inner {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card--selected .card__index-inner {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  box-shadow: 0 4rpx 12rpx var(--color-shadow-primary);
}

.card__num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-hint);
  line-height: 1;
}

.card--selected .card__num {
  color: #fff;
}

.card__check {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.card__content {
  flex: 1;
  padding-right: 16rpx;
}

.card__topic {
  font-size: 32rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  font-weight: 450;
}

.card--selected .card__topic {
  color: var(--color-primary);
  font-weight: 600;
}

.card__selected-icon {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 700;
  padding-right: 8rpx;
}
