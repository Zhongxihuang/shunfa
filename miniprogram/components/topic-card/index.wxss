.card {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(247, 243, 235, 0.94));
  border-radius: 32rpx;
  padding: 24rpx 24rpx 24rpx 18rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid rgba(188, 181, 170, 0.58);
  box-shadow: 0 12rpx 32rpx rgba(61, 53, 42, 0.06);
  transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  height: 6rpx;
  border-radius: 0 0 8rpx 8rpx;
  background: linear-gradient(90deg, rgba(156, 172, 153, 0.4), rgba(87, 110, 92, 0.16));
}

.card--hover {
  transform: translateY(-2rpx);
  box-shadow: 0 16rpx 36rpx rgba(61, 53, 42, 0.08);
}

.card--selected {
  border-color: rgba(87, 110, 92, 0.46);
  background: linear-gradient(180deg, rgba(252, 250, 244, 0.98) 0%, rgba(244, 248, 243, 0.98) 100%);
  box-shadow: 0 16rpx 40rpx rgba(74, 90, 74, 0.1);
}

.card__rail {
  flex-shrink: 0;
  width: 72rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 10rpx;
}

.card__index-inner {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: rgba(238, 234, 224, 0.9);
  border: 1.5rpx solid rgba(188, 181, 170, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
}

.card--selected .card__index-inner {
  background: linear-gradient(180deg, var(--color-accent-deep) 0%, #3f4640 100%);
  box-shadow: 0 8rpx 18rpx rgba(63, 70, 64, 0.16);
  border-color: transparent;
}

.card__num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-ink-soft);
  line-height: 1;
}

.card--selected .card__num {
  color: #fff;
}

.card__check {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.card__content {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card__topic {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  color: var(--color-ink);
  line-height: 1.5;
  font-weight: 650;
  font-family: var(--font-family-display);
}

.card__selected-pill {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  color: var(--color-primary-dark);
  background: rgba(156, 172, 153, 0.18);
  border: 1.5rpx solid rgba(87, 110, 92, 0.22);
}

.card__source {
  display: block;
  font-size: 22rpx;
  color: var(--color-ink-muted);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

.card__summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-ink-soft);
  line-height: 1.68;
  margin-top: 12rpx;
}

.card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1.5rpx solid rgba(188, 181, 170, 0.5);
}

.card__link-label {
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.card__copy {
  font-size: 22rpx;
  color: var(--color-primary-dark);
  font-weight: 650;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(156, 172, 153, 0.18);
  border: 1.5rpx solid rgba(87, 110, 92, 0.16);
}

.card--selected .card__topic {
  color: var(--color-ink);
  font-weight: 700;
}
