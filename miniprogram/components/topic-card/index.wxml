<view
  class="card {{selected ? 'card--selected' : ''}}"
  bindtap="onTap"
  hover-class="card--hover"
>
  <view class="card__rail">
    <view class="card__index-inner">
      <text wx:if="{{selected}}" class="card__check">✓</text>
      <text wx:else class="card__num">{{index}}</text>
    </view>
  </view>

  <view class="card__content">
    <view class="card__header">
      <text class="card__topic">{{topic}}</text>
      <text wx:if="{{selected}}" class="card__selected-pill">已选</text>
    </view>

    <text class="card__source">{{source}}</text>
    <text class="card__summary">{{summary}}</text>

    <view wx:if="{{url}}" class="card__footer">
      <text class="card__link-label">原文链接已保留</text>
      <text class="card__copy" catchtap="onCopyLink">复制链接</text>
    </view>
  </view>
</view>
