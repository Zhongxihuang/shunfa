.diamond-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, #eef2ff, #e8eaf6);
  border: 1.5rpx solid rgba(92, 107, 192, 0.2);
  box-shadow: var(--shadow-card);
  flex: 1;
  justify-content: center;
}
.diamond-icon { font-size: 34rpx; line-height: 1; }
.diamond-count { font-size: 40rpx; font-weight: 800; color: #3f51b5; line-height: 1; }
