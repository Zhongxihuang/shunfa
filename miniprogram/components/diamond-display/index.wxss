.diamond-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98) 0%, rgba(246, 241, 233, 0.98) 100%);
  border: 2rpx solid rgba(182, 172, 153, 0.52);
  box-shadow: 0 8rpx 24rpx rgba(43, 35, 24, 0.06);
  flex: 1;
  justify-content: center;
}
.diamond-icon { font-size: 32rpx; line-height: 1; opacity: 0.86; }
.diamond-count { font-size: 38rpx; font-weight: 600; color: var(--color-ink); line-height: 1; font-family: var(--font-family-display); }
