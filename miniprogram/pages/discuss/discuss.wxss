.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f0f0;
}

.topic-header {
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.topic-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.topic-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-top: 4rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: scroll;
}

.message-item {
  margin-bottom: 24rpx;
  display: flex;
}

.message-item.user {
  justify-content: flex-end;
}

.message-item.assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
}

.message-item.user .bubble {
  background: #07c160;
  border-bottom-right-radius: 4rpx;
}

.message-item.user .message-text {
  color: #fff;
}

.message-item.assistant .bubble {
  background: #fff;
  border-bottom-left-radius: 4rpx;
}

.message-item.assistant .message-text {
  color: #333;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.5;
  display: block;
}

.message-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-top: 6rpx;
  text-align: right;
}

.message-item.assistant .message-time {
  color: #999;
}

.loading-bubble {
  padding: 16rpx 24rpx;
}

.input-area {
  display: flex;
  align-items: flex-end;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input {
  flex: 1;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  max-height: 200rpx;
  min-height: 72rpx;
}

.send-btn {
  margin-left: 16rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  min-width: 120rpx;
}

.send-btn.disabled {
  background: #ccc;
}
