<view class="container">
  <view class="header paper-card">
    <view class="header__topline">
      <text class="eyebrow">草稿</text>
      <text class="pill">{{step === 'preview' ? '待确认' : step === 'quality_result' ? '已给出提示' : '处理中'}}</text>
    </view>
    <text class="header__title">把这一条整理顺，再决定发不发</text>
    <text class="header__subtitle">素材和链接都已经保留下来。这里不需要再追信息，只需要把判断写清楚。</text>
  </view>

  <view class="post-preview paper-card">
    <view class="post-preview__heading">
      <text class="section-label">主题</text>
      <text class="post-preview__topic">{{topic}}</text>
    </view>

    <view wx:if="{{topicSource || topicUrl || topicSummary}}" class="post-preview__fact-card soft-card">
      <view class="post-preview__fact-header">
        <text class="post-preview__fact-title">参考信息</text>
        <text wx:if="{{topicSource}}" class="pill pill-accent">{{topicSource}}</text>
      </view>
      <text wx:if="{{topicSummary}}" class="post-preview__fact-summary">{{topicSummary}}</text>
      <view wx:if="{{topicUrl}}" class="post-preview__fact-link-row">
        <text class="post-preview__fact-link-label">原文链接已保留</text>
        <text class="btn-text" catchtap="onCopySourceLink">复制链接</text>
      </view>
    </view>

    <text class="post-preview__content">{{content || '...'}}</text>
    <view class="post-preview__footer">
      <text class="post-preview__time">顺发起稿</text>
      <text class="post-preview__platform">可发布文本</text>
    </view>
  </view>

  <view wx:if="{{step === 'preview' || step === 'quality_check'}}" class="draft-area paper-card">
    <view class="draft-area__header">
      <view>
        <text class="draft-area__title">正文修改区</text>
        <text class="draft-area__hint">保留观点，不用把语气磨平。</text>
      </view>
      <text class="{{content.length < 140 || content.length > 220 ? 'count-warning' : 'count-ok'}}">{{content.length}} 字</text>
    </view>
    <textarea
      class="draft-input"
      value="{{content}}"
      bindinput="onContentChange"
      placeholder="编辑你的内容..."
      auto-height="true"
      maxlength="500"
      disabled="{{step === 'quality_check'}}"
    />
    <text class="count-hint">建议 140-220 字，够短，也够有判断。</text>
  </view>

  <view wx:if="{{step === 'quality_result'}}" class="quality-card quality-card--{{qualityPass ? 'pass' : 'fail'}}">
    <view class="quality-header">
      <text class="quality-title">{{qualityPass ? '这版已经能发' : '这版还可以再收一收'}}</text>
      <text class="pill {{qualityPass ? 'pill-accent' : ''}}">{{qualityPass ? '可发布' : '建议再改'}}</text>
    </view>

    <view wx:if="{{qualityIssues.length > 0}}" class="quality-issues">
      <text class="quality-issue-label">编辑提示</text>
      <text wx:for="{{qualityIssues}}" wx:key="index" class="quality-issue">{{item}}</text>
    </view>

    <view class="quality-actions">
      <button class="btn-secondary quality-actions__secondary" bindtap="onBackToEdit">返回修改</button>
      <button
        wx:if="{{!qualityPass}}"
        class="btn-secondary quality-actions__secondary"
        bindtap="onSendFeedback"
        disabled="{{feedbackSent}}"
      >
        {{feedbackSent ? '已记为一般' : '记为一般'}}
      </button>
      <button
        class="btn-primary quality-actions__primary {{submitting ? 'quality-actions__primary--loading' : ''}}"
        bindtap="onPublish"
        disabled="{{submitting}}"
      >
        {{submitting ? '发布中...' : '照样发布'}}
      </button>
    </view>
  </view>

  <view wx:if="{{step === 'quality_check'}}" class="quality-loading paper-card">
    <view class="loading-spinner"></view>
    <text class="quality-loading-text">正在看这版有没有跑偏...</text>
  </view>

  <view wx:if="{{step === 'publishing'}}" class="quality-loading paper-card">
    <view class="loading-spinner"></view>
    <text class="quality-loading-text">正在签发这条内容...</text>
  </view>

  <view wx:if="{{step === 'preview'}}" class="actions">
    <button class="btn-secondary actions__secondary" bindtap="onRegenerate">返回上一步</button>
    <button
      class="btn-primary actions__primary {{submitting ? 'actions__primary--loading' : ''}}"
      bindtap="onCheckQuality"
      disabled="{{submitting || !content}}"
    >
      {{submitting ? '评估中...' : '确认发布'}}
    </button>
  </view>
</view>
