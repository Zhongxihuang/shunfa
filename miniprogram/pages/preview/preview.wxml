<view class="container">
  <view class="header">
    <text class="title">预览初稿</text>
    <text class="subtitle">你可以在发布前修改内容 ✏️</text>
  </view>

  <!-- Post Preview Card -->
  <view class="post-preview">
    <text class="post-preview__topic"># {{topic}}</text>
    <text class="post-preview__content">{{content || '...'}}</text>
    <view class="post-preview__footer">
      <text class="post-preview__time">刚刚</text>
      <text class="post-preview__platform">小红书 · 顺发</text>
    </view>
  </view>

  <!-- Editable area (only in preview step) -->
  <view wx:if="{{step === 'preview' || step === 'quality_check'}}" class="draft-area">
    <textarea
      class="draft-input"
      value="{{content}}"
      bindinput="onContentChange"
      placeholder="编辑你的内容..."
      auto-height="true"
      maxlength="500"
      disabled="{{step === 'quality_check'}}"
    />
    <view class="char-count">
      <text class="{{content.length < 140 || content.length > 220 ? 'count-warning' : 'count-ok'}}">
        {{content.length}} 字
      </text>
      <text class="count-hint">建议 140-220 字</text>
    </view>
  </view>

  <!-- Quality Check Result -->
  <view wx:if="{{step === 'quality_result'}}" class="quality-card quality-card--{{qualityPass ? 'pass' : 'fail'}}">
    <view wx:if="{{qualityPass}}" class="quality-header quality-header--pass">
      <text class="quality-icon">✅</text>
      <text class="quality-title">内容质量良好</text>
    </view>
    <view wx:if="{{!qualityPass}}" class="quality-header quality-header--fail">
      <text class="quality-icon">💡</text>
      <text class="quality-title">内容可以更好</text>
    </view>

    <view wx:if="{{qualityIssues.length > 0}}" class="quality-issues">
      <text class="quality-issue-label">建议优化：</text>
      <text wx:for="{{qualityIssues}}" wx:key="index" class="quality-issue">· {{item}}</text>
    </view>

    <view class="quality-actions">
      <button class="btn-ghost-small" bindtap="onBackToEdit">返回修改</button>
      <button
        class="btn-primary-small {{submitting ? 'loading' : ''}}"
        bindtap="onPublish"
        disabled="{{submitting}}"
      >
        {{submitting ? '发布中...' : '仍然发布'}}
      </button>
    </view>
  </view>

  <!-- Step: Quality check loading -->
  <view wx:if="{{step === 'quality_check'}}" class="quality-loading">
    <view class="loading-spinner"></view>
    <text class="quality-loading-text">AI 评估中...</text>
  </view>

  <!-- Step: Publishing -->
  <view wx:if="{{step === 'publishing'}}" class="quality-loading">
    <view class="loading-spinner"></view>
    <text class="quality-loading-text">发布中...</text>
  </view>

  <!-- Primary CTA (preview step only) -->
  <view wx:if="{{step === 'preview'}}" class="actions">
    <button class="btn-secondary" bindtap="onRegenerate">← 返回修改</button>
    <button
      class="btn-primary {{submitting ? 'loading' : ''}}"
      bindtap="onCheckQuality"
      disabled="{{submitting || !content}}"
    >
      {{submitting ? '评估中...' : '🚀 确认发布'}}
    </button>
  </view>
</view>
