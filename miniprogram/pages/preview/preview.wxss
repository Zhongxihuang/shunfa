.container {
  min-height: 100vh;
  padding: 28rpx 24rpx 84rpx;
}

.header,
.post-preview,
.draft-area,
.quality-card,
.quality-loading,
.error-banner,
.actions {
  margin-bottom: 20rpx;
}

.error-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, rgba(243, 234, 223, 0.9) 0%, rgba(255, 253, 250, 0.96) 48%);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
}

.error-banner__title {
  font-size: 32rpx;
  font-weight: 650;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.error-banner__desc {
  font-size: 26rpx;
  color: var(--color-ink-soft);
  text-align: center;
}

.error-banner__btn {
  margin-top: 8rpx;
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--color-ink);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
  border: none;
}

.header {
  padding: 32rpx 30rpx 30rpx;
}

.header__topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.header__title {
  display: block;
  margin-top: 22rpx;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 700;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.header__subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.66;
  color: var(--color-ink-soft);
}

.post-preview {
  padding: 32rpx 30rpx;
}

.post-preview__heading {
  margin-bottom: 18rpx;
}

.post-preview__topic {
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  line-height: 1.4;
  font-weight: 650;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.post-preview__fact-card {
  padding: 22rpx 24rpx;
  margin-bottom: 22rpx;
}

.post-preview__fact-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.post-preview__fact-title {
  font-size: 24rpx;
  color: var(--color-ink-soft);
  font-weight: 600;
}

.post-preview__fact-summary {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.64;
  color: var(--color-ink-soft);
}

.post-preview__fact-link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
}

.post-preview__fact-link-label {
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.post-preview__content {
  font-size: 32rpx;
  line-height: 1.82;
  color: var(--color-ink);
  white-space: pre-wrap;
}

.post-preview__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--color-border);
}

.post-preview__time,
.post-preview__platform {
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.draft-area {
  padding: 26rpx 28rpx;
}

.draft-area__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.draft-area__title {
  display: block;
  font-size: 30rpx;
  color: var(--color-ink);
  font-weight: 600;
  font-family: var(--font-family-display);
}

.draft-area__hint {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.draft-input {
  width: 100%;
  min-height: 260rpx;
  font-size: 30rpx;
  line-height: 1.82;
  color: var(--color-ink);
}

.count-ok,
.count-warning,
.count-over-limit {
  font-size: 24rpx;
  font-weight: 600;
}

.count-ok {
  color: var(--color-accent-deep);
}

.count-warning {
  color: var(--color-danger);
}

.count-over-limit {
  color: #fff;
  background: var(--color-danger);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 700;
}

.count-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.quality-card {
  padding: 28rpx 30rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.quality-card--pass {
  background: linear-gradient(180deg, rgba(142, 165, 146, 0.14) 0%, rgba(255, 253, 250, 0.96) 46%);
}

.quality-card--fail {
  background: linear-gradient(180deg, rgba(243, 234, 223, 0.9) 0%, rgba(255, 253, 250, 0.96) 48%);
}

.quality-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.quality-title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 650;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.quality-issues {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 20rpx;
}

.quality-issue-label {
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  color: var(--color-ink-muted);
}

.quality-issue {
  font-size: 25rpx;
  line-height: 1.62;
  color: var(--color-ink-soft);
}

.quality-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 22rpx;
}

.quality-actions__secondary {
  flex: 1;
  min-width: 210rpx;
  width: 100%;
}

.quality-actions__primary {
  flex: 1.2;
  min-width: 240rpx;
  width: 100%;
}

.quality-actions__primary--loading,
.actions__primary--loading {
  background: #cbc8c1;
  box-shadow: none;
}

.quality-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 38rpx 24rpx;
}

.quality-loading-text {
  font-size: 27rpx;
  color: var(--color-ink-soft);
}

.actions {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.actions__secondary {
  flex: 1;
  width: 100%;
}

.actions__primary {
  flex: 1.35;
  width: 100%;
}
