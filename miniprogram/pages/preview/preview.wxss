.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

.draft-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.draft-input {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  line-height: 1.7;
  min-height: 300rpx;
}

.char-count {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 16rpx;
  gap: 16rpx;
}

.count-ok { color: #07c160; font-size: 26rpx; }
.count-warning { color: #fa5151; font-size: 26rpx; }
.count-hint { color: #999; font-size: 24rpx; }

.actions {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  font-size: 32rpx;
}

.btn-primary {
  flex: 2;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
}

.btn-primary.loading {
  background: #ccc;
}
