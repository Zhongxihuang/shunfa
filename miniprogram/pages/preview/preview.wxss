.container {
  padding: 32rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

.header {
  margin-bottom: 28rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Post Preview Card — how it will actually look */
.post-preview {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

.post-preview::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--color-primary), #0dab4f, #fab005);
}

.post-preview__topic {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
}

.post-preview__content {
  font-size: 32rpx;
  color: var(--color-text-primary);
  line-height: 1.75;
  white-space: pre-wrap;
}

.post-preview__footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-preview__time {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.post-preview__platform {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* Editable Draft Area */
.draft-area {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.draft-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.75;
  min-height: 240rpx;
}

.char-count {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.count-ok { color: var(--color-primary); font-size: 24rpx; font-weight: 600; }
.count-warning { color: #fa5151; font-size: 24rpx; font-weight: 600; }
.count-hint { color: var(--color-text-hint); font-size: 22rpx; }

/* Actions */
.actions {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  font-size: 32rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}
.btn-secondary::after { border: none; }
.btn-secondary:active { background: var(--color-bg); }

.btn-primary {
  flex: 2;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  border-radius: var(--radius-pill);
  font-size: 34rpx;
  font-weight: 700;
  padding: 28rpx;
  box-shadow: var(--shadow-primary);
  letter-spacing: 1rpx;
}
.btn-primary::after { border: none; }
.btn-primary:active { transform: scale(0.97); opacity: 0.9; }
.btn-primary.loading {
  background: #e0e0e0;
  box-shadow: none;
}

/* Quality Check Card */
.quality-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 20rpx;
}
.quality-loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.quality-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid transparent;
}

.quality-card--pass {
  border-left-color: var(--color-primary);
  background: linear-gradient(135deg, #f0fff6 0%, var(--color-bg-card) 60%);
}

.quality-card--fail {
  border-left-color: #fab005;
  background: linear-gradient(135deg, #fffbf0 0%, var(--color-bg-card) 60%);
}

.quality-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.quality-icon { font-size: 40rpx; }

.quality-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.quality-issues {
  background: rgba(0,0,0,0.04);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.quality-issue-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.quality-issue {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.quality-actions {
  display: flex;
  gap: 16rpx;
}

.btn-ghost-small {
  flex: 1;
  background: transparent;
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  font-size: 30rpx;
  padding: 22rpx;
}
.btn-ghost-small::after { border: none; }
.btn-ghost-small:active { background: var(--color-bg); }

.btn-primary-small {
  flex: 2;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  border-radius: var(--radius-pill);
  font-size: 30rpx;
  font-weight: 700;
  padding: 22rpx;
  box-shadow: var(--shadow-primary);
}
.btn-primary-small::after { border: none; }
.btn-primary-small:active { transform: scale(0.97); opacity: 0.9; }
.btn-primary-small.loading {
  background: #e0e0e0;
  box-shadow: none;
}
