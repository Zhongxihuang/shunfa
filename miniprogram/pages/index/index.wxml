<view class="container">
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:elif="{{userInfo}}" class="main anim-fade-in">
    <view class="hero paper-card">
      <view class="hero__topline">
        <text class="eyebrow">顺发</text>
        <text class="pill">{{todayCompleted ? '今日已完成' : '今日待发'}}</text>
      </view>

      <view class="hero__body">
        <text class="hero__title">{{todayCompleted ? '今天已经发出一条' : '今天，先发一条'}}</text>
        <text class="hero__subtitle">
          {{todayCompleted ? '今天已经续上了。明天再来，继续轻一点地表达。' : '不用等准备完整。先选一个角度，把你的判断发出去。'}}
        </text>
      </view>

      <view class="hero__metrics">
        <view class="hero__metric">
          <text class="hero__metric-value">{{userInfo.streak}}</text>
          <text class="hero__metric-label">当前连更</text>
        </view>
        <view class="hero__metric">
          <text class="hero__metric-value">{{userInfo.longest_streak}}</text>
          <text class="hero__metric-label">最长记录</text>
        </view>
        <view class="hero__metric">
          <text class="hero__metric-value">Lv.{{userInfo.level}}</text>
          <text class="hero__metric-label">当前等级</text>
        </view>
      </view>
    </view>

    <view class="primary-action paper-card">
      <view class="primary-action__head">
        <view>
          <text class="section-label">今日动作</text>
          <text class="primary-action__title">{{todayCompleted ? '今天的写作动作已经完成' : '把今天的写作动作做完'}}</text>
        </view>
        <text class="primary-action__state">{{todayCompleted ? '已完成' : '进行中'}}</text>
      </view>

      <text class="primary-action__desc">
        {{todayCompleted ? '保持轻量、稳定、持续，比多写一版更重要。' : '系统已经准备好 3 条热点。你现在只需要做一个选择。'}}
      </text>

      <button wx:if="{{!todayCompleted}}" class="btn-primary primary-action__button" bindtap="onStartWriting">
        开始今日写作
      </button>

      <view wx:else class="primary-action__complete soft-card">
        <text class="primary-action__complete-title">今天的节奏已经续上</text>
        <text class="primary-action__complete-text">明天再来，继续把表达变成更稳定的习惯。</text>
      </view>
    </view>

    <view class="summary-grid">
      <view class="summary-card paper-card">
        <text class="section-label">写作进度</text>
        <view class="summary-card__component">
          <level-progress level="{{userInfo.level}}" points="{{userInfo.points}}" />
        </view>
      </view>

      <view class="summary-card paper-card">
        <text class="section-label">累计状态</text>
        <view class="summary-card__badges">
          <streak-badge streak="{{userInfo.streak}}" longest-streak="{{userInfo.longest_streak}}" />
          <diamond-display diamonds="{{userInfo.diamonds}}" />
        </view>
      </view>
    </view>

    <view class="gentle-note note-card">
      <text class="gentle-note__title">提醒</text>
      <text class="gentle-note__text">顺发负责把起步变轻。真正让内容有分量的，还是你的判断。</text>
    </view>
  </view>
</view>
