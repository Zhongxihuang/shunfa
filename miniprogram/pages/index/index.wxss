.container {
  min-height: 100vh;
  padding: 28rpx 0 84rpx;
  background: transparent;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero,
.primary-action,
.summary-card,
.gentle-note {
  margin: 0 24rpx;
}

.hero {
  padding: 34rpx 30rpx 32rpx;
}

.hero__topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero__body {
  margin-top: 26rpx;
}

.hero__title {
  display: block;
  font-size: 68rpx;
  line-height: 1.05;
  font-weight: 700;
  color: var(--color-ink);
  letter-spacing: -1.5rpx;
  font-family: var(--font-family-display);
}

.hero__subtitle {
  display: block;
  margin-top: 14rpx;
  max-width: 600rpx;
  font-size: 28rpx;
  line-height: 1.68;
  color: var(--color-ink-soft);
}

.hero__metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 28rpx;
}

.hero__metric {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.54);
  border: 2rpx solid rgba(133, 128, 118, 0.14);
}

.hero__metric-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 600;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.hero__metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.45;
  color: var(--color-ink-muted);
}

.primary-action {
  padding: 30rpx;
}

.primary-action__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.primary-action__head > view {
  flex: 1;
  min-width: 0;
}

.primary-action__title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 650;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.primary-action__state {
  flex-shrink: 0;
  margin-top: 2rpx;
  padding: 10rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--color-accent-soft);
  border: 2rpx solid rgba(111, 135, 115, 0.16);
  color: var(--color-accent-deep);
  font-size: 22rpx;
}

.primary-action__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.66;
  color: var(--color-ink-soft);
}

.primary-action__button {
  width: 100%;
  margin-top: 24rpx;
}

.primary-action__complete {
  margin-top: 22rpx;
  padding: 24rpx;
}

.primary-action__complete-title {
  display: block;
  font-size: 28rpx;
  color: var(--color-ink);
  font-weight: 600;
  font-family: var(--font-family-display);
}

.primary-action__complete-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-ink-soft);
}

.summary-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-card {
  padding: 28rpx 28rpx 28rpx;
}

.summary-card__component {
  margin-top: 16rpx;
}

.summary-card__badges {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.gentle-note {
  padding: 22rpx 28rpx;
}

.gentle-note__title {
  display: block;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: rgba(131, 107, 72, 0.86);
}

.gentle-note__text {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.62;
  color: var(--color-ink-soft);
}
