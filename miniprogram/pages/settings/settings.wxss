.container {
  padding: 28rpx 24rpx 72rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

.header {
  padding: 28rpx 28rpx 30rpx;
  margin-bottom: 22rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.98) 0%, rgba(249, 244, 235, 0.98) 100%);
}

.header__topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.header__status {
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-ink);
  line-height: 1.08;
  margin-bottom: 10rpx;
  font-family: var(--font-family-display);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-ink-soft);
  line-height: 1.6;
}

.settings-kicker {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-ink-muted);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.settings-card {
  padding: 6rpx 28rpx;
  margin-bottom: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.98) 0%, rgba(249, 244, 235, 0.98) 100%);
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 2rpx dashed rgba(182, 172, 153, 0.7);
}

.setting-row:last-child { border-bottom: none; }

.setting-copy {
  flex: 1;
}

.setting-label {
  display: block;
  font-size: 32rpx;
  color: var(--color-ink);
  font-weight: 700;
  font-family: var(--font-family-display);
}

.setting-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-ink-muted);
  line-height: 1.55;
}

.time-display {
  font-size: 32rpx;
  color: var(--color-ink);
  font-weight: 700;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(232, 238, 228, 0.92);
  border: 2rpx solid rgba(182, 172, 153, 0.56);
  font-family: var(--font-family-display);
}

.save-btn {
  width: 100%;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.save-btn::after { border: none; }
.save-btn:active { transform: scale(0.98); opacity: 0.94; }

.save-btn.saving,
.save-btn[disabled] {
  background: #d8d2c8;
  color: #8f8777;
  box-shadow: none;
}

.note {
  padding: 22rpx 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.98) 0%, rgba(245, 240, 231, 0.98) 100%);
}

.note__label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-ink-soft);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.note__text {
  display: block;
  font-size: 26rpx;
  color: var(--color-ink-soft);
  line-height: 1.6;
}
