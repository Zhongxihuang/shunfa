.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #666;
  font-size: 28rpx;
}

.topic-list {
  margin-bottom: 30rpx;
}

.topic-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
}

.topic-card.selected {
  border-color: #07c160;
  background: #f0fff4;
}

.topic-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
}

.refresh-area {
  text-align: center;
  margin-bottom: 30rpx;
}

.refresh-btn {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
}

.refresh-btn.disabled {
  color: #ccc;
  border-color: #ccc;
}

.custom-input-area {
  margin-bottom: 30rpx;
}

.toggle-custom-btn {
  background: transparent;
  color: #666;
  font-size: 28rpx;
  border: none;
  text-decoration: underline;
}

.custom-input {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.custom-input input {
  font-size: 30rpx;
  color: #333;
  width: 100%;
}

.confirm-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.confirm-btn[disabled] {
  background: #ccc;
}
