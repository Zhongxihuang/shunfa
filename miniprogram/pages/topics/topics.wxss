.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

/* Hero */
.hero {
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(160deg, #fff8e1 0%, #fff3cd 40%, transparent 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  margin-bottom: 32rpx;
}

.hero__eyebrow {
  font-size: 24rpx;
  color: #f5a623;
  font-weight: 600;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  line-height: 1.1;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: var(--color-text-hint);
  font-size: 28rpx;
  gap: 20rpx;
}

.topic-list {
  margin: 0 32rpx 24rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: calc(100% - 64rpx);
  margin: 0 32rpx 28rpx;
  height: 80rpx;
  background: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid rgba(7, 193, 96, 0.3);
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: var(--shadow-card);
}
.refresh-btn::after { border: none; }
.refresh-btn:active { background: var(--color-primary-light); }

.refresh-btn--disabled {
  color: var(--color-text-hint);
  border-color: var(--color-border);
}

.refresh-count {
  font-size: 22rpx;
  opacity: 0.7;
}

.divider {
  display: flex;
  align-items: center;
  margin: 0 32rpx 28rpx;
}
.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}
.divider-text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.custom-area {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin: 0 32rpx 32rpx;
  box-shadow: var(--shadow-card);
}

.custom-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.custom-toggle__label {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.custom-toggle__arrow {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.custom-input-wrap {
  padding: 0 32rpx 28rpx;
  border-top: 1rpx solid var(--color-border);
}

.custom-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--color-text-primary);
  padding: 20rpx 0 8rpx;
  box-sizing: border-box;
}

.custom-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 6rpx;
}

.confirm-btn {
  width: calc(100% - 64rpx);
  margin: 0 32rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  border-radius: var(--radius-pill);
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: var(--shadow-primary);
  letter-spacing: 2rpx;
}
.confirm-btn::after { border: none; }
.confirm-btn:active { transform: scale(0.97); opacity: 0.9; }
.confirm-btn[disabled] {
  background: #e0e0e0;
  color: #bbb;
  box-shadow: none;
}
