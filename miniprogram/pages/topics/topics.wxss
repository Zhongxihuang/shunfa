.container {
  padding: 32rpx 32rpx 60rpx;
  min-height: 100vh;
  background: #f7f7f7;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
  gap: 20rpx;
}

/* 卡片样式已移入 topic-card 组件 */
.topic-list {
  margin-bottom: 32rpx;
}

.refresh-btn {
  width: 100%;
  height: 80rpx;
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 50rpx;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.refresh-btn--disabled {
  color: #ccc;
  border-color: #e0e0e0;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
}

.divider-text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #bbb;
}

.custom-area {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.custom-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.custom-toggle__label {
  font-size: 30rpx;
  color: #333;
}

.custom-toggle__arrow {
  font-size: 24rpx;
  color: #999;
}

.custom-input-wrap {
  padding: 0 32rpx 28rpx;
  border-top: 1rpx solid #f5f5f5;
}

.custom-input {
  width: 100%;
  font-size: 30rpx;
  color: #1a1a1a;
  padding: 20rpx 0 8rpx;
  box-sizing: border-box;
}

.custom-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #0dab4f);
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn[disabled] {
  background: #e0e0e0;
  color: #bbb;
  box-shadow: none;
}
