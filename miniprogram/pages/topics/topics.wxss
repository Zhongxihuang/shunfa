.container {
  min-height: 100vh;
  padding: 28rpx 0 84rpx;
}

.hero,
.empty-panel,
.selection-footer,
.confirm-btn {
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.hero {
  padding: 32rpx 30rpx 30rpx;
  margin-bottom: 20rpx;
}

.hero__topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero__title {
  display: block;
  margin-top: 22rpx;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 700;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.hero__subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: var(--color-ink-soft);
}

.empty-panel {
  padding: 34rpx 30rpx;
}

.empty-panel__title {
  display: block;
  font-size: 36rpx;
  line-height: 1.28;
  font-weight: 650;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.empty-panel__desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.66;
  color: var(--color-ink-soft);
}

.empty-panel__btn {
  margin-top: 24rpx;
}

.topic-list {
  margin: 0 24rpx 20rpx;
}

.selection-footer {
  padding: 24rpx 28rpx;
}

.selection-footer__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.selection-footer__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.selection-footer__desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--color-ink-soft);
}

.confirm-btn {
  width: calc(100% - 48rpx);
  margin-top: 22rpx;
}

.confirm-btn[disabled] {
  background: #cbc8c1;
  color: #8a877f;
  box-shadow: none;
}
