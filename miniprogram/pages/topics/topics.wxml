<view class="container">
  <view class="hero">
    <text class="hero__eyebrow">今日写作</text>
    <text class="title">选一个话题</text>
    <text class="subtitle">说出你的故事，世界想听</text>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text>正在生成选题...</text>
  </view>

  <view wx:else>
    <view class="topic-list">
      <topic-card
        wx:for="{{topics}}"
        wx:key="topic"
        topic="{{item.topic}}"
        index="{{index + 1}}"
        selected="{{selectedTopic === item.topic}}"
        bindselect="onSelectTopic"
      />
    </view>

    <button
      class="refresh-btn {{refreshCount >= maxRefreshes ? 'refresh-btn--disabled' : ''}}"
      bindtap="onRefresh"
      disabled="{{refreshCount >= maxRefreshes || loading}}"
    >
      ↻ 换一批 <text class="refresh-count">（还剩 {{maxRefreshes - refreshCount}} 次）</text>
    </button>

    <view class="divider"><text class="divider-text">或者</text></view>

    <view class="custom-area">
      <view class="custom-toggle" bindtap="onToggleCustomInput">
        <text class="custom-toggle__label">✏️ 自己来写选题</text>
        <text class="custom-toggle__arrow">{{showCustomInput ? '∧' : '∨'}}</text>
      </view>
      <view wx:if="{{showCustomInput}}" class="custom-input-wrap">
        <input
          class="custom-input"
          placeholder="写下你想聊的话题..."
          bindinput="onCustomInput"
          value="{{customTopic}}"
          maxlength="50"
          focus="{{showCustomInput}}"
        />
        <text class="custom-count">{{customTopic.length}}/50</text>
      </view>
    </view>

    <button
      class="confirm-btn"
      bindtap="onConfirmTopic"
      disabled="{{!selectedTopic && !customTopic}}"
    >
      开始写作 →
    </button>
  </view>
</view>
