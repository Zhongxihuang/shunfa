.container {
  padding: 28rpx 0 72rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

/* Header */
.header {
  margin: 0 24rpx 24rpx;
  padding: 32rpx 30rpx;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.98) 0%, rgba(250, 245, 237, 0.98) 100%);
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(182, 172, 153, 0.25);
  box-shadow:
    0 2rpx 8rpx rgba(43, 35, 24, 0.04),
    0 8rpx 24rpx rgba(43, 35, 24, 0.06);
  animation: fadeInUp 0.4s ease-out both;
}

.header__title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-ink);
  font-family: var(--font-family-display);
  letter-spacing: -0.5rpx;
}

.header__subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-ink-muted);
}

/* Draft List */
.draft-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 24rpx;
}

.draft-item {
  padding: 26rpx 28rpx 24rpx;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.96) 0%, rgba(250, 245, 237, 0.96) 100%);
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(182, 172, 153, 0.25);
  box-shadow:
    0 2rpx 8rpx rgba(43, 35, 24, 0.04),
    0 6rpx 20rpx rgba(43, 35, 24, 0.05);
  transition: all 0.22s ease;
  animation: fadeInUp 0.4s ease-out both;
  position: relative;
  overflow: hidden;
}

.draft-item:nth-child(1) { animation-delay: 0.1s; }
.draft-item:nth-child(2) { animation-delay: 0.14s; }
.draft-item:nth-child(3) { animation-delay: 0.18s; }
.draft-item:nth-child(4) { animation-delay: 0.22s; }
.draft-item:nth-child(5) { animation-delay: 0.26s; }
.draft-item:nth-child(n+6) { animation-delay: 0.3s; }

.draft-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5rpx;
  background: linear-gradient(180deg, #c9a86c 0%, #a8895a 100%);
}

.draft-item:active {
  transform: scale(0.99);
  background: rgba(245, 240, 231, 0.92);
}

.draft-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.draft-item__date {
  font-size: 22rpx;
  color: var(--color-ink-muted);
  font-weight: 500;
}

.draft-item__status {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.draft-item__status--topic_selected,
.draft-item__status--discussing,
.draft-item__status--draft_ready,
.draft-item__status--pending {
  background: linear-gradient(160deg, rgba(218, 199, 160, 0.32) 0%, rgba(218, 199, 160, 0.2) 100%);
  color: #8a7040;
}

.draft-item__topic {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
  line-height: 1.45;
  font-family: var(--font-family-display);
  letter-spacing: -0.3rpx;
  margin-bottom: 4rpx;
}

.draft-item__source {
  margin-top: 10rpx;
}

.draft-item__source-text {
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.draft-item__actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.btn-continue {
  padding: 16rpx 40rpx;
  background: linear-gradient(160deg, rgba(142, 165, 146, 0.2) 0%, rgba(142, 165, 146, 0.12) 100%);
  border: 2rpx solid rgba(111, 135, 115, 0.25);
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-accent-deep);
  line-height: 1;
  transition: all 0.22s ease;
  box-shadow: 0 4rpx 12rpx rgba(111, 135, 115, 0.1);
}

.btn-continue:active {
  transform: scale(0.97);
  background: rgba(142, 165, 146, 0.28);
  box-shadow: 0 2rpx 6rpx rgba(111, 135, 115, 0.1);
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 24rpx;
  color: var(--color-ink-muted);
  font-size: 28rpx;
}

.loading-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 4rpx solid rgba(182, 172, 153, 0.2);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Empty Panel */
.empty-panel {
  margin: 0 24rpx;
  padding: 56rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.96) 0%, rgba(250, 245, 237, 0.96) 100%);
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(182, 172, 153, 0.25);
  box-shadow:
    0 2rpx 8rpx rgba(43, 35, 24, 0.04),
    0 8rpx 24rpx rgba(43, 35, 24, 0.06);
  animation: fadeInUp 0.4s ease-out both;
}

.empty-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.empty-panel__desc {
  font-size: 26rpx;
  color: var(--color-ink-muted);
  line-height: 1.65;
  max-width: 480rpx;
}

.empty-panel__btn {
  margin-top: 24rpx;
  font-size: 28rpx;
  padding: 20rpx 52rpx;
  background: linear-gradient(160deg, rgba(142, 165, 146, 0.18) 0%, rgba(142, 165, 146, 0.1) 100%);
  border: 2rpx solid rgba(111, 135, 115, 0.22);
  border-radius: var(--radius-pill);
  color: var(--color-accent-deep);
  font-weight: 600;
  transition: all 0.2s ease;
}

.empty-panel__btn:active {
  transform: scale(0.98);
  background: rgba(142, 165, 146, 0.25);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
