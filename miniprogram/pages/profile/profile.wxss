.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.loading { text-align: center; padding: 100rpx; color: #999; }

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.diamond-row {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.diamond-label { font-size: 32rpx; color: #333; }
.diamond-value { font-size: 40rpx; font-weight: bold; color: #5c6bc0; }

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-text { font-size: 32rpx; color: #333; }
.menu-arrow { font-size: 36rpx; color: #ccc; }

.achievements-section {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.achievements-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.achievement-badge {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  min-width: 140rpx;
}

.achievement-icon {
  font-size: 44rpx;
}

.achievement-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}
