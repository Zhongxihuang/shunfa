<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{userInfo}}" class="main">
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-value">{{userInfo.streak}}</text>
        <text class="stat-label">当前连更</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{userInfo.longest_streak}}</text>
        <text class="stat-label">最长连更</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{userInfo.points}}</text>
        <text class="stat-label">总积分</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">Lv.{{userInfo.level}}</text>
        <text class="stat-label">当前等级</text>
      </view>
    </view>

    <view class="diamond-row">
      <text class="diamond-label">💎 钻石</text>
      <text class="diamond-value">{{userInfo.diamonds}}</text>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="onGoSettings">
        <text class="menu-text">⏰ 提醒设置</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
