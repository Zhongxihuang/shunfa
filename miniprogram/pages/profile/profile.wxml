<view class="container">
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:elif="{{userInfo}}" class="main">
    <view class="hero paper-card">
      <view class="hero__header">
        <view class="hero__avatar">
          <text class="hero__avatar-text">{{userInfo.nickname || '写'}}</text>
        </view>
        <view class="hero__meta">
          <text class="profile-kicker">个人写作档案</text>
          <text class="hero__greeting">{{userInfo.streak > 0 ? '保持这个节奏，写作会越来越轻' : '从今天开始，把发声变成习惯'}}</text>
          <text class="hero__subtitle">当前连更 {{userInfo.streak}} 天 · 最长连更 {{userInfo.longest_streak}} 天</text>
        </view>
      </view>
      <view class="hero__memo note-card">
        <text class="hero__memo-label">写作备注</text>
        <text class="hero__memo-text">你积累的不是任务数，而是稳定表达的手感。</text>
      </view>
    </view>

    <view class="stats-grid">
      <view class="stat-card paper-card">
        <text class="stat-kicker">当前</text>
        <text class="stat-value">{{userInfo.streak}}</text>
        <text class="stat-label">当前连更</text>
      </view>
      <view class="stat-card paper-card">
        <text class="stat-kicker">最佳</text>
        <text class="stat-value">{{userInfo.longest_streak}}</text>
        <text class="stat-label">最长连更</text>
      </view>
      <view class="stat-card paper-card">
        <text class="stat-kicker">积分</text>
        <text class="stat-value">{{userInfo.points}}</text>
        <text class="stat-label">累计积分</text>
      </view>
      <view class="stat-card paper-card">
        <text class="stat-kicker">等级</text>
        <text class="stat-value">Lv.{{userInfo.level}}</text>
        <text class="stat-label">当前等级</text>
      </view>
    </view>

    <view class="quick-actions">
      <view class="quick-action" bindtap="onGoHistory" data-filter="completed">
        <view class="quick-action__icon">稿</view>
        <view class="quick-action__meta">
          <text class="quick-action__title">我的稿件</text>
          <text class="quick-action__desc">已完成的创作</text>
        </view>
        <text class="quick-action__arrow">›</text>
      </view>
      <view class="quick-action" bindtap="onGoDrafts">
        <view class="quick-action__icon quick-action__icon--draft">草</view>
        <view class="quick-action__meta">
          <text class="quick-action__title">草稿箱</text>
          <text class="quick-action__desc">中断的创作</text>
        </view>
        <view wx:if="{{draftCount > 0}}" class="quick-action__badge">{{draftCount}}</view>
        <text wx:else class="quick-action__arrow">›</text>
      </view>
      <view class="quick-action" bindtap="onGoSettings">
        <view class="quick-action__icon quick-action__icon--settings">时</view>
        <view class="quick-action__meta">
          <text class="quick-action__title">提醒设置</text>
          <text class="quick-action__desc">安排每日提醒</text>
        </view>
        <text class="quick-action__arrow">›</text>
      </view>
    </view>

    <view wx:if="{{recentCheckins.length > 0}}" class="recent-section">
      <view class="section-header">
        <text class="section-label">最近创作</text>
        <text class="section-more" bindtap="onGoHistory">查看全部 ›</text>
      </view>
      <view class="recent-list">
        <view
          wx:for="{{recentCheckins}}"
          wx:key="id"
          class="recent-item paper-card"
          bindtap="onViewCheckin"
          data-id="{{item.id}}"
        >
          <view class="recent-item__header">
            <text class="recent-item__date">{{item.date}}</text>
            <view class="recent-item__status recent-item__status--{{item.status}}">
              <text wx:if="{{item.status === 'completed'}}">已发布</text>
              <text wx:elif="{{item.status === 'draft'}}">草稿</text>
              <text wx:elif="{{item.status === 'topic_selected'}}">待讨论</text>
              <text wx:elif="{{item.status === 'discussing'}}">讨论中</text>
              <text wx:elif="{{item.status === 'draft_ready'}}">待发布</text>
              <text wx:else>{{item.status}}</text>
            </view>
          </view>
          <text class="recent-item__topic">{{item.topic}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{achievements.length > 0}}" class="achievements-section">
      <text class="section-label">已解锁习惯</text>
      <view class="achievements-grid">
        <view wx:for="{{achievements}}" wx:key="type" class="achievement-badge">
          <text class="achievement-icon">{{item.icon || '章'}}</text>
          <view class="achievement-info">
            <text class="achievement-name">{{item.name}}</text>
            <text class="achievement-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{achievements.length === 0}}" class="achievements-section">
      <view class="achievements-empty note-card">
        <text>完成首次发布后，这里会出现你的第一枚记录。</text>
      </view>
    </view>
  </view>
</view>
