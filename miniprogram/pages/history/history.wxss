.container {
  padding: 28rpx 0 72rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

/* Header */
.header {
  margin: 0 24rpx 24rpx;
  padding: 32rpx 30rpx;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.98) 0%, rgba(250, 245, 237, 0.98) 100%);
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(182, 172, 153, 0.25);
  box-shadow:
    0 2rpx 8rpx rgba(43, 35, 24, 0.04),
    0 8rpx 24rpx rgba(43, 35, 24, 0.06);
  animation: fadeInUp 0.4s ease-out both;
}

.header__title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-ink);
  font-family: var(--font-family-display);
  letter-spacing: -0.5rpx;
}

.header__subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-ink-muted);
}

/* Tabs */
.tabs {
  display: flex;
  gap: 0;
  margin: 0 24rpx 24rpx;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.88) 0%, rgba(250, 245, 237, 0.88) 100%);
  border-radius: var(--radius-sm);
  padding: 6rpx;
  border: 2rpx solid rgba(182, 172, 153, 0.22);
  box-shadow: 0 4rpx 16rpx rgba(43, 35, 24, 0.04);
  animation: fadeInUp 0.4s ease-out both;
  animation-delay: 0.08s;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: var(--color-ink-muted);
  border-radius: 12rpx;
  transition: all 0.25s ease;
  position: relative;
}

.tab-item--active {
  background: linear-gradient(160deg, rgba(142, 165, 146, 0.22) 0%, rgba(142, 165, 146, 0.14) 100%);
  color: var(--color-accent-deep);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(111, 135, 115, 0.12);
}

.tab-item:active:not(.tab-item--active) {
  background: rgba(245, 240, 231, 0.7);
}

/* Checkin List */
.checkin-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 24rpx;
}

.checkin-item {
  padding: 26rpx 28rpx 24rpx;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.96) 0%, rgba(250, 245, 237, 0.96) 100%);
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(182, 172, 153, 0.25);
  box-shadow:
    0 2rpx 8rpx rgba(43, 35, 24, 0.04),
    0 6rpx 20rpx rgba(43, 35, 24, 0.05);
  transition: all 0.22s ease;
  animation: fadeInUp 0.4s ease-out both;
  position: relative;
  overflow: hidden;
}

.checkin-item:nth-child(1) { animation-delay: 0.1s; }
.checkin-item:nth-child(2) { animation-delay: 0.14s; }
.checkin-item:nth-child(3) { animation-delay: 0.18s; }
.checkin-item:nth-child(4) { animation-delay: 0.22s; }
.checkin-item:nth-child(5) { animation-delay: 0.26s; }
.checkin-item:nth-child(n+6) { animation-delay: 0.3s; }

.checkin-item:active {
  transform: scale(0.99);
  background: rgba(245, 240, 231, 0.92);
}

.checkin-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5rpx;
  background: linear-gradient(180deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.checkin-item--completed::before {
  opacity: 1;
}

.checkin-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.checkin-item__date {
  font-size: 22rpx;
  color: var(--color-ink-muted);
  font-weight: 500;
}

.checkin-item__badge {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.checkin-item__badge--completed {
  background: linear-gradient(160deg, rgba(142, 165, 146, 0.2) 0%, rgba(142, 165, 146, 0.12) 100%);
  color: var(--color-accent-deep);
}

.checkin-item__badge--draft,
.checkin-item__badge--topic_selected,
.checkin-item__badge--discussing,
.checkin-item__badge--draft_ready,
.checkin-item__badge--pending {
  background: linear-gradient(160deg, rgba(218, 199, 160, 0.32) 0%, rgba(218, 199, 160, 0.2) 100%);
  color: #8a7040;
}

.checkin-item__topic {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
  line-height: 1.45;
  font-family: var(--font-family-display);
  letter-spacing: -0.3rpx;
  margin-bottom: 4rpx;
}

.checkin-item__source {
  margin-top: 10rpx;
}

.checkin-item__source-text {
  font-size: 22rpx;
  color: var(--color-ink-muted);
}

.checkin-item__preview {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  background: linear-gradient(160deg, rgba(245, 240, 231, 0.7) 0%, rgba(240, 235, 225, 0.7) 100%);
  border-radius: 14rpx;
  border: 1rpx solid rgba(182, 172, 153, 0.15);
}

.checkin-item__preview-text {
  font-size: 26rpx;
  color: var(--color-ink-soft);
  line-height: 1.65;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.checkin-item__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(182, 172, 153, 0.2);
}

.checkin-item__points {
  font-size: 24rpx;
  color: var(--color-accent-deep);
  font-weight: 600;
}

.checkin-item__arrow {
  font-size: 38rpx;
  color: var(--color-ink-muted);
  font-weight: 300;
  transition: transform 0.2s ease;
}

.checkin-item:active .checkin-item__arrow {
  transform: translateX(4rpx);
}

/* Load More */
.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-ink-muted);
  transition: opacity 0.2s;
}

.load-more:active {
  opacity: 0.7;
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 24rpx;
  color: var(--color-ink-muted);
  font-size: 28rpx;
}

.loading-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 4rpx solid rgba(182, 172, 153, 0.2);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Empty Panel */
.empty-panel {
  margin: 0 24rpx;
  padding: 56rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
  background: linear-gradient(160deg, rgba(255, 253, 248, 0.96) 0%, rgba(250, 245, 237, 0.96) 100%);
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(182, 172, 153, 0.25);
  box-shadow:
    0 2rpx 8rpx rgba(43, 35, 24, 0.04),
    0 8rpx 24rpx rgba(43, 35, 24, 0.06);
  animation: fadeInUp 0.4s ease-out both;
}

.empty-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-ink);
  font-family: var(--font-family-display);
}

.empty-panel__desc {
  font-size: 26rpx;
  color: var(--color-ink-muted);
  line-height: 1.65;
  max-width: 480rpx;
}

.empty-panel__btn {
  margin-top: 24rpx;
  font-size: 28rpx;
  padding: 20rpx 52rpx;
  background: linear-gradient(160deg, rgba(142, 165, 146, 0.18) 0%, rgba(142, 165, 146, 0.1) 100%);
  border: 2rpx solid rgba(111, 135, 115, 0.22);
  border-radius: var(--radius-pill);
  color: var(--color-accent-deep);
  font-weight: 600;
  transition: all 0.2s ease;
}

.empty-panel__btn:active {
  transform: scale(0.98);
  background: rgba(142, 165, 146, 0.25);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
