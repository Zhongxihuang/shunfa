<view class="container">
  <view class="header paper-card">
    <text class="header__title">历史稿件</text>
    <text class="header__subtitle">你的每一次表达轨迹</text>
  </view>

  <view class="tabs">
    <view
      class="tab-item {{activeTab === 'all' ? 'tab-item--active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="all"
    >
      全部
    </view>
    <view
      class="tab-item {{activeTab === 'completed' ? 'tab-item--active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="completed"
    >
      已发布
    </view>
    <view
      class="tab-item {{activeTab === 'draft' ? 'tab-item--active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="draft"
    >
      草稿
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="empty-panel paper-card">
    <text class="empty-panel__title">加载失败</text>
    <text class="empty-panel__desc">网络或服务端出了点问题，请稍后重试。</text>
    <button class="empty-panel__btn" bindtap="onRetryLoad">重新加载</button>
  </view>

  <view wx:elif="{{checkins.length === 0}}" class="empty-panel paper-card">
    <view wx:if="{{activeTab === 'all'}}">
      <text class="empty-panel__title">还没有创作记录</text>
      <text class="empty-panel__desc">从今日热点开始，写下你的第一条内容。</text>
      <button class="empty-panel__btn" bindtap="onGoTopics">去选题</button>
    </view>
    <view wx:elif="{{activeTab === 'completed'}}">
      <text class="empty-panel__title">还没有已发布的内容</text>
      <text class="empty-panel__desc">完成创作并发布后，这里会出现你的作品。</text>
    </view>
    <view wx:else>
      <text class="empty-panel__title">草稿箱是空的</text>
      <text class="empty-panel__desc">所有创作都已完成，没有中断的草稿。</text>
    </view>
  </view>

  <view wx:else class="checkin-list">
    <view
      wx:for="{{checkins}}"
      wx:key="id"
      class="checkin-item checkin-item--{{item.status}} paper-card"
      bindtap="onViewCheckin"
      data-id="{{item.id}}"
      data-status="{{item.status}}"
    >
      <view class="checkin-item__header">
        <text class="checkin-item__date">{{item.date}}</text>
        <view class="checkin-item__badge checkin-item__badge--{{item.status}}">
          <text wx:if="{{item.status === 'completed'}}">已发布</text>
          <text wx:elif="{{item.status === 'draft'}}">草稿</text>
          <text wx:elif="{{item.status === 'topic_selected'}}">待讨论</text>
          <text wx:elif="{{item.status === 'discussing'}}">讨论中</text>
          <text wx:elif="{{item.status === 'draft_ready'}}">待发布</text>
          <text wx:else>{{item.status}}</text>
        </view>
      </view>
      <text class="checkin-item__topic">{{item.topic}}</text>
      <view wx:if="{{item.topic_source}}" class="checkin-item__source">
        <text class="checkin-item__source-text">来源：{{item.topic_source}}</text>
      </view>
      <view wx:if="{{item.content}}" class="checkin-item__preview">
        <text class="checkin-item__preview-text">{{item.content}}</text>
      </view>
      <view class="checkin-item__footer">
        <text wx:if="{{item.points_earned > 0}}" class="checkin-item__points">+{{item.points_earned}} 积分</text>
        <text class="checkin-item__arrow">›</text>
      </view>
    </view>

    <view wx:if="{{hasMore}}" class="load-more" bindtap="onLoadMore">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:else>加载更多</text>
    </view>
  </view>
</view>
