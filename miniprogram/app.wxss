page {
  --color-bg: #f6f3ee;
  --color-bg-elevated: #fbf9f6;
  --color-surface: rgba(255, 253, 250, 0.92);
  --color-surface-strong: #fffdfb;
  --color-surface-muted: #f1ece4;
  --color-surface-tint: rgba(216, 226, 218, 0.52);
  --color-accent: #8ea592;
  --color-accent-strong: #6f8773;
  --color-accent-soft: rgba(142, 165, 146, 0.16);
  --color-accent-deep: #46554b;
  --color-primary: var(--color-accent);
  --color-primary-dark: var(--color-accent-deep);
  --color-primary-soft: var(--color-accent-soft);
  --color-ink: #222320;
  --color-ink-soft: #50524b;
  --color-ink-muted: #86887f;
  --color-highlight: #ebe2d5;
  --color-highlight-soft: #f4ece1;
  --color-border: rgba(133, 128, 118, 0.18);
  --color-border-strong: rgba(124, 120, 111, 0.28);
  --color-danger: #b56a5b;
  --color-danger-soft: rgba(181, 106, 91, 0.12);
  --color-success: #728b77;
  --color-shadow: rgba(25, 25, 25, 0.06);
  --color-shadow-strong: rgba(25, 25, 25, 0.1);
  --color-shadow-primary: rgba(111, 135, 115, 0.12);
  --color-switch: #8ea592;
  --color-bg-card: var(--color-surface);
  --color-bg-card-strong: var(--color-surface-strong);
  --radius-xs: 18rpx;
  --radius-sm: 24rpx;
  --radius-md: 32rpx;
  --radius-lg: 42rpx;
  --radius-pill: 999rpx;
  --shadow-card: 0 18rpx 50rpx var(--color-shadow);
  --shadow-soft: 0 10rpx 28rpx rgba(35, 35, 35, 0.05);
  --shadow-accent: 0 14rpx 36rpx rgba(111, 135, 115, 0.12);
  --shadow-primary: var(--shadow-accent);
  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  --font-family-display: 'Iowan Old Style', 'Palatino Linotype', 'Baskerville', 'Times New Roman', 'Songti SC', 'STSong', 'Noto Serif SC', 'Source Han Serif SC', serif;
  background: linear-gradient(180deg, #f8f5f1 0%, #f3efe8 100%);
  color: var(--color-ink);
  font-family: var(--font-family);
  font-size: 30rpx;
  line-height: 1.6;
}

.h1 { font-size: 60rpx; font-weight: 700; line-height: 1.1; letter-spacing: -1rpx; }
.h2 { font-size: 42rpx; font-weight: 650; line-height: 1.25; }
.h3 { font-size: 34rpx; font-weight: 600; line-height: 1.35; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-secondary { color: var(--color-ink-soft); }
.text-hint { color: var(--color-ink-muted); }
.font-display {
  font-family: var(--font-family-display);
  letter-spacing: -0.5rpx;
}

.card,
.paper-card {
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(12rpx);
}

.note-card {
  background: linear-gradient(180deg, rgba(255, 249, 241, 0.98) 0%, rgba(248, 243, 236, 0.98) 100%);
  border: 2rpx solid rgba(170, 151, 123, 0.2);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
}

.soft-card {
  background: var(--color-surface-tint);
  border: 2rpx solid rgba(142, 165, 146, 0.18);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
}

.eyebrow,
.section-label {
  display: inline-block;
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: var(--color-ink-muted);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  border: 2rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.1;
  color: var(--color-ink-soft);
  box-sizing: border-box;
  white-space: nowrap;
}

.pill-accent {
  color: var(--color-accent-deep);
  border-color: rgba(111, 135, 115, 0.18);
  background: rgba(142, 165, 146, 0.12);
}

.btn-primary {
  background: linear-gradient(180deg, #414741 0%, #2d302d 100%);
  color: #fcfbf8;
  border: none;
  border-radius: var(--radius-pill);
  min-height: 92rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0 42rpx;
  line-height: 1.2;
  box-shadow: var(--shadow-accent);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.btn-primary::after { border: none; }
.btn-primary:active { transform: scale(0.985); opacity: 0.96; }

.btn-secondary {
  background: rgba(255, 253, 250, 0.84);
  color: var(--color-ink);
  border: 2rpx solid var(--color-border-strong);
  border-radius: var(--radius-pill);
  min-height: 92rpx;
  font-size: 30rpx;
  padding: 0 34rpx;
  line-height: 1.2;
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.btn-secondary::after { border: none; }
.btn-secondary:active { transform: scale(0.99); opacity: 0.96; }

.btn-text {
  color: var(--color-accent-deep);
  font-size: 24rpx;
  font-weight: 600;
}

.divider {
  height: 2rpx;
  background: var(--color-border);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(18rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.anim-fade-in { animation: fadeInUp 0.24s ease-out both; }

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(120, 120, 120, 0.18);
  border-top-color: var(--color-accent-deep);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 16rpx auto;
}

.loading-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--color-ink-muted);
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.error-text {
  color: var(--color-danger);
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--color-ink-muted);
  font-size: 28rpx;
}

.section {
  padding: 40rpx 24rpx;
}

.section-title {
  font-size: 22rpx;
  color: var(--color-ink-muted);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}
