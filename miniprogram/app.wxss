/* ===========================
   DESIGN TOKENS
   =========================== */
page {
  --color-primary: #07c160;
  --color-primary-dark: #05964a;
  --color-primary-light: #e8fdf0;
  --color-bg: #f7f9fa;
  --color-bg-card: #ffffff;
  --color-text-primary: #1a1a2e;
  --color-text-secondary: #636e7b;
  --color-text-hint: #adb5bd;
  --color-border: #e9ecef;
  --color-shadow: rgba(0, 0, 0, 0.06);
  --color-shadow-primary: rgba(7, 193, 96, 0.18);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-pill: 999rpx;
  --shadow-card: 0 4rpx 24rpx var(--color-shadow);
  --shadow-primary: 0 8rpx 32rpx var(--color-shadow-primary);
  --shadow-hover: 0 8rpx 40rpx var(--color-shadow-primary);
  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background-color: var(--color-bg);
  font-family: var(--font-family);
  color: var(--color-text-primary);
  font-size: 30rpx;
  line-height: 1.6;
}

/* ===========================
   TYPOGRAPHY
   =========================== */
.h1 { font-size: 52rpx; font-weight: 800; line-height: 1.2; }
.h2 { font-size: 40rpx; font-weight: 700; line-height: 1.3; }
.h3 { font-size: 34rpx; font-weight: 600; line-height: 1.4; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-secondary { color: var(--color-text-secondary); }
.text-hint { color: var(--color-text-hint); }

/* ===========================
   CARD
   =========================== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}

/* ===========================
   BUTTONS
   =========================== */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  border: none;
  border-radius: var(--radius-pill);
  font-size: 34rpx;
  font-weight: 600;
  padding: 28rpx 48rpx;
  box-shadow: var(--shadow-primary);
  line-height: 1;
}
.btn-primary::after { border: none; }
.btn-primary:active { transform: scale(0.97); opacity: 0.9; }

.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-pill);
  font-size: 30rpx;
  padding: 22rpx 40rpx;
  line-height: 1;
}
.btn-ghost::after { border: none; }
.btn-ghost:active { background: var(--color-primary-light); }

/* ===========================
   ANIMATIONS
   =========================== */
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.anim-fade-in { animation: fadeInUp 0.4s ease-out both; }

/* ===========================
   LOADING / ERROR / EMPTY
   =========================== */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 20rpx auto;
}

.loading-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: var(--color-text-hint);
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.error-text {
  color: #fa5151;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-hint);
  font-size: 30rpx;
}

/* ===========================
   SHARED SECTION SPACING
   =========================== */
.section { padding: 40rpx 32rpx; }
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-hint);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}
